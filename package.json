{
  "name": "evv-monitor",
  "version": "1.0.0",
  "description": "Backend service that discovers and monitors EVV (Electronic Visit Verification) regulatory websites for content changes",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "tsx watch src/index.ts",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "tsx src/seed.ts",
    "db:seed:prod": "node dist/seed.js",
    "lint": "eslint src/"
  },
  "dependencies": {
    "@mozilla/readability": "^0.5.0",
    "@prisma/client": "^6.4.1",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cron": "^3.3.1",
    "crypto-random-string": "^5.0.0",
    "diff": "^7.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsdom": "^25.0.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.6.0",
    "playwright": "^1.50.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/diff": "^7.0.1",
    "@types/express": "^5.0.0",
    "@types/jsdom": "^21.1.7",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.13.4",
    "prisma": "^6.4.1",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
