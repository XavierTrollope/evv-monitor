# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXXXXXX

# Search API (Google Custom Search)
SEARCH_API_KEY=your-google-api-key
SEARCH_ENGINE_ID=your-custom-search-engine-id

# Database — PostgreSQL (used by Docker Compose; override for external DB)
# Docker Compose sets this automatically — only change for external PostgreSQL
DATABASE_URL=postgresql://evv:evv_monitor_secret@db:5432/evv_monitor

# PostgreSQL password (used by docker-compose.yml)
POSTGRES_PASSWORD=evv_monitor_secret

# Scheduling
DISCOVERY_CRON=0 8 * * *
DEFAULT_POLL_INTERVAL_MIN=60

# Change detection
CHANGE_THRESHOLD_PCT=5

# Playwright
PLAYWRIGHT_TIMEOUT_MS=15000

# API server
PORT=3000

# Optional: base URL for "View full diff" links in Slack messages
DIFF_VIEWER_BASE_URL=http://localhost:3000/changes
